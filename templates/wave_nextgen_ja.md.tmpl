            {"type": "add_dod", "issue_id": "issue-id", "description": "人間向け説明", "detail": "追記する具体的な内容"}
          ],
          "prerequisites": [],
          "delta": {"before": 0.65, "after": 0.80},
          "status": "available"
        }
      ],
