FROM golang:1.26-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/sightjack ./cmd/sightjack/

FROM alpine:3.21
RUN apk add --no-cache git
COPY --from=builder /bin/sightjack /usr/local/bin/sightjack
WORKDIR /workspace
CMD ["sleep", "infinity"]
