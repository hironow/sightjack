# Stage 1: Build sightjack + fake-claude
FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/sightjack ./cmd/sightjack/
RUN CGO_ENABLED=0 go build -o /bin/fake-claude ./tests/e2e/fake-claude/

# Stage 2: Runtime (keeps Go toolchain for go test -tags e2e)
FROM golang:1.25-alpine AS runtime
RUN apk add --no-cache git
COPY --from=builder /bin/sightjack /usr/local/bin/sightjack
COPY --from=builder /bin/fake-claude /usr/local/bin/claude
COPY --from=builder /src /src
WORKDIR /src
